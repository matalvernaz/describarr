# AudioVault credentials
AUDIOVAULT_EMAIL=your@email.com
AUDIOVAULT_PASSWORD=yourpassword

# Minimum alignment score (0-100) to keep a combined file. Default: 65
AD_SYNC_MIN_SCORE=65

# Directory for caching downloaded season zips and alignment reports.
# Default: ~/.cache/ad-sync
# AD_SYNC_CACHE_DIR=/path/to/cache
